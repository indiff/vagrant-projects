require 'yaml'
require 'ipaddr'

VAGRANTFILE_API_VERSION = '2'

# ----------------------------- Project identity ------------------------------
PROJECT_TITLE   = 'Oracle FPP 19c (19.3.0) on Oracle Linux 7'
BOX_NAME        = 'oraclelinux/7'
BOX_URL         = 'https://oracle.github.io/vagrant-projects/boxes/oraclelinux/7.json'
BOX_MIN_VERSION = '>= 7.8.142'

# Each installer filename must start with this prefix. Prevents accidentally
# pointing the 19c project at a 21c/23ai zip.
EXPECTED_GI_SOFTWARE_PREFIX = 'LINUX.X64_193'
EXPECTED_DB_SOFTWARE_PREFIX = 'LINUX.X64_193'

# Canonical version identifiers (drive ORACLE_HOME paths, preinstall package
# selection, etc.). Kept as constants so they cannot be overridden by the YAML.
GI_VERSION = '19.3.0.0'
DB_VERSION = '19.3.0.0'
DB_MAJOR   = '19'

# Minimum resources — guard against accidentally-tiny configs.
MIN_VM1_MEM_MB   = 12_288
MIN_VM2_MEM_MB   = 6_144
MIN_ASM_DISK_NUM = 4
MIN_ASM_DISK_GB  = 10

# --------------------------- Banner ------------------------------------------
puts ''
puts '--------------------------------------------------------'
puts "  #{PROJECT_TITLE}"
puts '  Vagrant project for VirtualBox or KVM/libvirt'
puts '  Copyright (c) 2020-2026 Oracle and/or its affiliates'
puts '--------------------------------------------------------'
puts ''

# --------------------------- Helpers -----------------------------------------
def fatal(msg)
  $stderr.puts "ERROR: #{msg}"
  $stderr.flush
  exit 1
end

def valid_ip?(str)
  !!IPAddr.new(str.to_s) rescue false
end

def require_ip!(label, value)
  fatal "#{label} is not a valid IP address (got: '#{value}')" unless valid_ip?(value)
end

def fetch_optional(hash, *path, default: nil)
  node = hash
  path.each do |key|
    return default unless node.is_a?(Hash) && node.key?(key)
    node = node[key]
  end
  node.nil? ? default : node
end

def verify_checksum_entry(checksum_path, installer)
  return false unless File.exist?(checksum_path)

  File.foreach(checksum_path) do |line|
    line = line.strip
    next if line.empty? || line.start_with?('#')

    parts = line.split(/\s+/, 3)
    next unless parts.length == 3
    return true if File.basename(parts[2]) == installer
  end
  false
end

# --------------------------- Config load -------------------------------------
config_path = File.expand_path('config/vagrant.yml', __dir__)
fatal "config file not found: #{config_path}" unless File.exist?(config_path)

begin
  params = YAML.load_file(config_path)
rescue => e
  fatal "failed to parse #{config_path}: #{e.message}"
end

fatal "config file #{config_path} is empty or not a mapping" unless params.is_a?(Hash)
%w[host1 host2 shared env].each do |section|
  fatal "missing required section '#{section}' in #{config_path}" unless params[section].is_a?(Hash)
end

# --------------------------- Extract config ----------------------------------
# env
var_provider_name   = params['env']['provider']
var_gi_software     = params['env']['gi_software']
var_db_software     = params['env']['db_software']
var_ora_languages   = params['env']['ora_languages']
var_root_password   = ENV['ORACLE_ROOT_PASSWORD']   || params['env']['root_password']
var_grid_password   = ENV['ORACLE_GRID_PASSWORD']   || params['env']['grid_password']
var_oracle_password = ENV['ORACLE_ORACLE_PASSWORD'] || params['env']['oracle_password']
var_sys_password    = ENV['ORACLE_SYS_PASSWORD']    || params['env']['sys_password']

# shared
var_prefix_name     = params['shared']['prefix_name']
var_network         = fetch_optional(params, 'shared', 'network',       default: 'hostonly').to_s
var_bridge_nic      = fetch_optional(params, 'shared', 'bridge_nic',    default: '').to_s
var_netmask         = fetch_optional(params, 'shared', 'netmask',       default: '').to_s
var_gateway         = fetch_optional(params, 'shared', 'gateway',       default: '').to_s
var_dns_public_ip   = fetch_optional(params, 'shared', 'dns_public_ip', default: '').to_s
var_domain          = fetch_optional(params, 'shared', 'domain',        default: 'localdomain').to_s
var_asm_disk_num    = params['shared']['asm_disk_num'].to_i
var_asm_disk_size   = params['shared']['asm_disk_size'].to_i
var_asm_lib_type    = fetch_optional(params, 'shared', 'asm_lib_type',  default: 'NONE').to_s
var_asm_lib_type    = 'NONE' if var_asm_lib_type.strip.empty?

# host1 (always deployed)
var_vm1_name        = params['host1']['vm_name']
var_vm1_mem_size    = params['host1']['mem_size'].to_i
var_vm1_cpus        = params['host1']['cpus'].to_i
var_vm1_public_ip   = params['host1']['public_ip']
var_vm1_vip_ip      = params['host1']['vip_ip']
var_vm1_private_ip  = params['host1']['private_ip']
var_scan_ip1        = params['host1']['scan_ip1']
var_scan_ip2        = params['host1']['scan_ip2']
var_scan_ip3        = params['host1']['scan_ip3']
var_gns_ip          = params['host1']['gns_ip']
var_ha_vip          = params['host1']['ha_vip']

# host2 (optional: deploy: 'false' ⇒ single-node Oracle Cluster)
var_vm2_deploy_raw  = fetch_optional(params, 'host2', 'deploy', default: 'true')
var_vm2_deploy      = var_vm2_deploy_raw.to_s.strip.downcase
var_deploy_host2    = (var_vm2_deploy == 'true')
var_vm2_name        = params['host2']['vm_name']
var_vm2_mem_size    = params['host2']['mem_size'].to_i
var_vm2_cpus        = params['host2']['cpus'].to_i
var_vm2_public_ip   = params['host2']['public_ip']
var_vm2_private_ip  = params['host2']['private_ip']

# --------------------------- Validation --------------------------------------
unless %w[libvirt virtualbox].include?(var_provider_name.to_s)
  fatal "'env.provider' must be 'libvirt' or 'virtualbox' (got: '#{var_provider_name}')"
end

unless var_prefix_name.is_a?(String) && var_prefix_name.match?(/\A[0-9a-zA-Z-]{1,14}\z/)
  fatal "'shared.prefix_name' must be 1-14 chars of [0-9a-zA-Z-] (got: '#{var_prefix_name}')"
end

unless %w[true false].include?(var_vm2_deploy)
  fatal "'host2.deploy' must be 'true' or 'false' (got: '#{var_vm2_deploy_raw}')"
end

unless %w[ASMLIB ASMFD NONE].include?(var_asm_lib_type)
  fatal "'shared.asm_lib_type' must be ASMLIB, ASMFD or NONE (got: '#{var_asm_lib_type}')"
end

unless %w[hostonly public].include?(var_network)
  fatal "'shared.network' must be 'public' or 'hostonly' (got: '#{var_network}')"
end

if var_network == 'public'
  fatal "'shared.bridge_nic' must be set when shared.network is 'public'"    if var_provider_name == 'libvirt' && var_bridge_nic.empty?
  fatal "'shared.gateway' must be set when shared.network is 'public'"       if var_gateway.empty?
  fatal "'shared.netmask' must be set when shared.network is 'public'"       if var_netmask.empty?
  fatal "'shared.dns_public_ip' must be set when shared.network is 'public'" if var_dns_public_ip.empty?
  require_ip!('shared.netmask',       var_netmask)
  require_ip!('shared.gateway',       var_gateway)
  require_ip!('shared.dns_public_ip', var_dns_public_ip)
end

fatal "'host1.mem_size' must be >= #{MIN_VM1_MEM_MB} MB (got: #{var_vm1_mem_size})" if var_vm1_mem_size < MIN_VM1_MEM_MB
fatal "'host1.cpus' must be >= 1 (got: #{var_vm1_cpus})"                            if var_vm1_cpus    < 1

fatal "'shared.asm_disk_num' must be >= #{MIN_ASM_DISK_NUM} (got: #{var_asm_disk_num})"      if var_asm_disk_num  < MIN_ASM_DISK_NUM
fatal "'shared.asm_disk_size' must be >= #{MIN_ASM_DISK_GB} GB (got: #{var_asm_disk_size})"  if var_asm_disk_size < MIN_ASM_DISK_GB

# host1 IPs — always validated.
{
  'host1.public_ip'  => var_vm1_public_ip,
  'host1.private_ip' => var_vm1_private_ip,
  'host1.vip_ip'     => var_vm1_vip_ip,
  'host1.scan_ip1'   => var_scan_ip1,
  'host1.scan_ip2'   => var_scan_ip2,
  'host1.scan_ip3'   => var_scan_ip3,
  'host1.gns_ip'     => var_gns_ip,
  'host1.ha_vip'     => var_ha_vip,
}.each { |label, val| require_ip!(label, val) }

# host2 — only required if actually deploying it.
if var_deploy_host2
  fatal "'host2.mem_size' must be >= #{MIN_VM2_MEM_MB} MB (got: #{var_vm2_mem_size})" if var_vm2_mem_size < MIN_VM2_MEM_MB
  fatal "'host2.cpus' must be >= 1 (got: #{var_vm2_cpus})"                            if var_vm2_cpus    < 1
  require_ip!('host2.public_ip',  var_vm2_public_ip)
  require_ip!('host2.private_ip', var_vm2_private_ip)
end

# Passwords.
{
  'env.root_password'   => var_root_password,
  'env.grid_password'   => var_grid_password,
  'env.oracle_password' => var_oracle_password,
  'env.sys_password'    => var_sys_password,
}.each do |label, val|
  fatal "'#{label}' must be set" if val.to_s.empty?
end

# Installer presence + filename prefix + checksum manifest entry.
gi_zip_path = File.expand_path("./ORCL_software/#{var_gi_software}", __dir__)
db_zip_path = File.expand_path("./ORCL_software/#{var_db_software}", __dir__)
fatal "GI installer zip not found: #{gi_zip_path}\n  Place the Oracle 19c Grid Infrastructure zip into ORCL_software/." unless File.exist?(gi_zip_path)
fatal "DB installer zip not found: #{db_zip_path}\n  Place the Oracle 19c Database zip into ORCL_software/."            unless File.exist?(db_zip_path)

unless var_gi_software.to_s.start_with?(EXPECTED_GI_SOFTWARE_PREFIX)
  fatal "'env.gi_software' (#{var_gi_software}) does not match this project (expected prefix: #{EXPECTED_GI_SOFTWARE_PREFIX})"
end
unless var_db_software.to_s.start_with?(EXPECTED_DB_SOFTWARE_PREFIX)
  fatal "'env.db_software' (#{var_db_software}) does not match this project (expected prefix: #{EXPECTED_DB_SOFTWARE_PREFIX})"
end

checksum_path = File.expand_path('./db_installer.cksum', __dir__)
fatal "installer checksum file not found: #{checksum_path}" unless File.exist?(checksum_path)
fatal "no checksum entry for '#{var_gi_software}' found in #{checksum_path}\n  Run:  cksum ORCL_software/#{var_gi_software}  and paste the result." unless verify_checksum_entry(checksum_path, var_gi_software)
fatal "no checksum entry for '#{var_db_software}' found in #{checksum_path}\n  Run:  cksum ORCL_software/#{var_db_software}  and paste the result." unless verify_checksum_entry(checksum_path, var_db_software)

# --------------------------- Provider setup ----------------------------------
provider = var_provider_name.to_sym
puts "Provider: #{provider}"
puts "Mode:     #{var_deploy_host2 ? 'single-node FPP Server cluster + FPP Client' : 'single-node FPP Server cluster (host2 skipped)'}"
puts ''

box_disks_num = 1

begin
  boxes_out = `vagrant box list 2>/dev/null`
  have_box  = boxes_out.lines.any? { |l| l.include?("#{BOX_NAME} (#{var_provider_name},") }
  unless have_box
    puts "NOTE: '#{BOX_NAME}' is not cached for provider '#{var_provider_name}'."
    puts "      Vagrant will download it now; expect a multi-GB transfer from yum.oracle.com."
    puts '      To pre-download (interactive progress), run in another shell:'
    puts "        vagrant box add #{BOX_NAME} #{BOX_URL} --provider=#{var_provider_name}"
    puts ''
  end
rescue StandardError
  # Best-effort notice; never block on failure.
end

# --------------------------- Storage setup -----------------------------------
if var_provider_name == 'libvirt'
  var_vm1_storage = fetch_optional(params, 'host1',  'storage_pool_name', default: 'default').to_s
  var_vm2_storage = fetch_optional(params, 'host2',  'storage_pool_name', default: 'default').to_s
  var_asm_storage = fetch_optional(params, 'shared', 'storage_pool_name', default: 'default').to_s
  var_vm1_storage = 'default' if var_vm1_storage.empty?
  var_vm2_storage = 'default' if var_vm2_storage.empty?
  var_asm_storage = 'default' if var_asm_storage.empty?
end

if var_provider_name == 'virtualbox'
  var_group          = fetch_optional(params, 'env',   'virtualbox_group', default: nil)
  var_vm1_u01_disk   = fetch_optional(params, 'host1', 'u01_disk',         default: './node1_u01.vdi').to_s
  var_vm2_u01_disk   = fetch_optional(params, 'host2', 'u01_disk',         default: './node2_u01.vdi').to_s
  var_non_rotational = fetch_optional(params, 'env',   'non_rotational',   default: 'on').to_s
  var_asm_disk_path  = fetch_optional(params, 'env',   'asm_disk_path',    default: '').to_s

  fatal "'env.non_rotational' must be 'on' or 'off' (got: '#{var_non_rotational}')" unless %w[on off].include?(var_non_rotational)

  if var_group == false || var_group.to_s.strip.empty?
    # Keep VirtualBox groups opt-in. Setting a group moves the VM directory on
    # the host and stale paths from interrupted imports can make `modifyvm
    # --groups` fail before the guest even boots.
    var_group = nil
  else
    var_group = var_group.to_s
    var_group = "/#{var_group}" unless var_group.start_with?('/')
  end
  var_asm_disk_path = var_asm_disk_path.empty? ? './' : "#{var_asm_disk_path}/"
  var_vm1_u01_disk  = './node1_u01.vdi' if var_vm1_u01_disk.empty?
  var_vm2_u01_disk  = './node2_u01.vdi' if var_vm2_u01_disk.empty?

  # Pre-create the shared ASM VDIs once, before any VM spins up. Doing this
  # from per-VM `vb.customize` would race when both nodes are brought up in
  # parallel (host1 could try to attach a VDI host2 has not yet created).
  var_asm_disk_num.times do |i|
    asm_disk = "#{var_asm_disk_path}asm_disk#{i}.vdi"
    next if File.exist?(asm_disk)

    puts "Creating shared ASM VDI: #{asm_disk} (#{var_asm_disk_size}G, fixed)"
    fatal "VBoxManage createhd failed for #{asm_disk}" unless system(
      'VBoxManage', 'createhd',
      '--filename', asm_disk,
      '--size',     (var_asm_disk_size * 1024).to_s,
      '--format',   'VDI',
      '--variant',  'Fixed'
    )
    fatal "VBoxManage modifymedium --type shareable failed for #{asm_disk}" unless system(
      'VBoxManage', 'modifymedium', 'disk', asm_disk, '--type', 'shareable'
    )
  end
end

# --------------------------- Required Vagrant plugins ------------------------
required_plugins = %w[vagrant-reload vagrant-proxyconf]
required_plugins << 'vagrant-libvirt' if var_provider_name == 'libvirt'

required_plugins.each do |plugin|
  next if Vagrant.has_plugin?(plugin)

  puts "Installing missing Vagrant plugin: #{plugin}"
  fatal "failed to install Vagrant plugin '#{plugin}'" unless system("vagrant plugin install #{plugin}")
end

# --------------------------- Time zone ---------------------------------------
offset_sec = Time.now.gmt_offset
if (offset_sec % 3600).zero?
  offset_hr           = offset_sec / 3600
  timezone_suffix     = offset_hr >= 0 ? "-#{offset_hr}" : "+#{-offset_hr}"
  var_system_timezone = "Etc/GMT#{timezone_suffix}"
else
  var_system_timezone = 'UTC'
end

# --------------------------- VM definition -----------------------------------
Vagrant.configure(VAGRANTFILE_API_VERSION) do |config|
  config.vm.box              = BOX_NAME
  config.vm.box_url          = BOX_URL
  config.vm.box_check_update = false
  config.vm.box_version      = BOX_MIN_VERSION if var_provider_name == 'virtualbox'

  config.vbguest.auto_update = false if Vagrant.has_plugin?('vagrant-vbguest')

  # Proxy configuration pulled from host environment (optional).
  if Vagrant.has_plugin?('vagrant-proxyconf')
    config.proxy.http     = ENV['http_proxy']  if ENV['http_proxy']
    config.proxy.https    = ENV['https_proxy'] if ENV['https_proxy']
    config.proxy.no_proxy = ENV['no_proxy']    if ENV['no_proxy']
  end

  if var_provider_name == 'libvirt'
    # The provisioner expects the project tree to be mounted at /vagrant.
    config.vm.synced_folder '.', '/vagrant', type: 'nfs'
  end

  # -------------------- libvirt --------------------
  if var_provider_name == 'libvirt'
    # Nodes are independent: host1 runs the GI install on its own (single-node
    # FPP Server cluster); host2 only does common OS prep + FPP Client setup.
    # Bringing them up in parallel is safe — the libvirt storage pool handles
    # the shared ASM volumes via `allow_existing` + `shareable`.
    nodes = []
    nodes << [:host1, var_vm1_name, var_vm1_mem_size, var_vm1_cpus,
              var_vm1_public_ip, var_vm1_private_ip, var_vm1_storage]
    if var_deploy_host2
      nodes << [:host2, var_vm2_name, var_vm2_mem_size, var_vm2_cpus,
                var_vm2_public_ip, var_vm2_private_ip, var_vm2_storage]
    end

    nodes.each do |vm_sym, vm_name, mem_size, cpus, public_ip, private_ip, vm_storage|
      config.vm.define vm_sym, primary: (vm_sym == :host1) do |node|
        node.vm.hostname = vm_name
        node.vm.network 'private_network', libvirt__network_name: 'vgt-hostonly_network', ip: public_ip
        node.vm.network 'private_network', libvirt__network_name: 'vgt-private_network',  ip: private_ip
        node.vm.provider :libvirt do |libvirt|
          libvirt.default_prefix    = var_prefix_name.end_with?('-') ? var_prefix_name : "#{var_prefix_name}-"
          libvirt.driver            = 'kvm'
          libvirt.memory            = mem_size
          libvirt.cpus              = cpus
          libvirt.graphics_type     = 'none'
          libvirt.storage_pool_name = vm_storage

          # u01 disk (per-node).
          libvirt.storage :file, size: '100G'

          # Shared ASM disks — attached to every node, created once on first use.
          libvirt.storage_pool_name = var_asm_storage
          var_asm_disk_num.times do |i|
            libvirt.storage :file,
                            path:           "#{var_prefix_name}_asm_#{i}",
                            size:           "#{var_asm_disk_size}G",
                            cache:          'none',
                            type:           'raw',
                            serial:         "asm_disk_#{i + 1}",
                            shareable:      'true',
                            allow_existing: 'true'
          end
        end
      end
    end
  end

  # -------------------- virtualbox -----------------
  if var_provider_name == 'virtualbox'
    # Nodes are independent: host1 runs the GI install on its own; host2 only
    # does common OS prep + FPP Client setup. Shared ASM VDIs are pre-created
    # above so both nodes can be brought up in parallel (`vagrant up --parallel`).
    vb_specs = []
    vb_specs << [:host1, var_vm1_name, var_vm1_mem_size, var_vm1_cpus,
                 var_vm1_public_ip, var_vm1_private_ip, var_vm1_u01_disk]
    if var_deploy_host2
      vb_specs << [:host2, var_vm2_name, var_vm2_mem_size, var_vm2_cpus,
                   var_vm2_public_ip, var_vm2_private_ip, var_vm2_u01_disk]
    end

    vb_specs.each do |vm_sym, vm_name, mem_size, cpus, public_ip, private_ip, u01_disk|
      config.vm.define vm_sym, primary: (vm_sym == :host1) do |node|
        node.vm.hostname = vm_name
        node.vm.network :private_network, ip: public_ip,  virtualbox__hostonly: 'vboxnet0'
        node.vm.network :private_network, ip: private_ip, virtualbox__intnet:   'private'

        node.vm.provider :virtualbox do |vb|
          vb.name   = "#{var_prefix_name}-#{vm_name}"
          vb.memory = mem_size
          vb.cpus   = cpus
          vb.customize ['modifyvm', :id, '--groups', var_group] unless var_group.nil?

          # Mark existing box disks non-rotational.
          (0...box_disks_num).each do |port|
            vb.customize ['storageattach', :id,
                          '--storagectl', 'SATA Controller',
                          '--port', port,
                          '--nonrotational', var_non_rotational]
          end

          disk_port = box_disks_num

          # u01 disk (per-node, persistent).
          unless File.exist?(u01_disk)
            vb.customize ['createhd', '--filename', u01_disk, '--size', 100 * 1024]
          end
          vb.customize ['storageattach', :id,
                        '--storagectl', 'SATA Controller',
                        '--port', disk_port, '--device', 0,
                        '--type', 'hdd', '--medium', u01_disk,
                        '--nonrotational', var_non_rotational]
          disk_port += 1

          # Shared ASM disks — already created and marked shareable above
          # (before any VM boots), so each node only needs to attach them.
          var_asm_disk_num.times do |i|
            asm_disk = "#{var_asm_disk_path}asm_disk#{i}.vdi"
            vb.customize ['storageattach', :id,
                          '--storagectl', 'SATA Controller',
                          '--port', disk_port, '--device', 0,
                          '--type', 'hdd', '--medium', asm_disk,
                          '--mtype', 'shareable',
                          '--nonrotational', var_non_rotational]
            disk_port += 1
          end
        end
      end
    end
  end

  # -------------------- ACFS prerequisite: UEK5 --------------------
  # ACFS on OL7 requires the UEK5 kernel; install it and reboot so it is the
  # running kernel before provisioning continues.
  config.vm.provision :shell, name: 'install-uek4' do |shell|
    shell.privileged = true
    shell.inline     = <<~SHELL
      set -euo pipefail
      echo "Installing UEK5 kernel (via yum)"
      sed -i '/enabled=0/c\\enabled=1' /etc/yum.repos.d/uek-ol7.repo
      yum install -y kernel-uek-4.1.12 kernel-uek-devel-4.1.12
      echo "Rebooting to make UEK5 the running kernel, a prerequisite for ACFS"
    SHELL
    shell.reboot = true
  end
  # Some libvirt/Vagrant combinations don't honour shell.reboot; force a reload.
  config.vm.provision :reload if var_provider_name == 'libvirt'

  # -------------------- Common provisioning --------------------
  # Enable SSH password auth (lab-internal only; Vagrant's synced folders and
  # ssh equivalence setup need it during provisioning).
  config.vm.provision 'shell', name: 'enable-ssh-password-auth', inline: <<~SHELL
    set -euo pipefail
    sed -ri 's/^[# ]*PasswordAuthentication[[:space:]]+.*/PasswordAuthentication yes/' /etc/ssh/sshd_config
    systemctl restart sshd
  SHELL

  # Main orchestrator.
  config.vm.provision 'shell', name: 'setup-orchestrator', path: 'scripts/setup.sh', env: {
    'PROVIDER'        => var_provider_name,
    'BOX_DISK_NUM'    => box_disks_num.to_s,
    'SYSTEM_TIMEZONE' => var_system_timezone,
    'PREFIX_NAME'     => var_prefix_name,
    'DOMAIN'          => var_domain,
    'NOMGMTDB'        => 'false',
    'GI_SOFTWARE'     => var_gi_software,
    'DB_SOFTWARE'     => var_db_software,
    'GI_VERSION'      => GI_VERSION,
    'DB_VERSION'      => DB_VERSION,
    'DB_MAJOR'        => DB_MAJOR,
    'ORA_LANGUAGES'   => var_ora_languages,
    'VM1_NAME'        => var_vm1_name,
    'VM2_NAME'        => var_vm2_name,
    'NODE1_PUBLIC_IP' => var_vm1_public_ip,
    'NODE1_PRIV_IP'   => var_vm1_private_ip,
    'NODE1_VIP_IP'    => var_vm1_vip_ip,
