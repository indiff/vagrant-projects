# ==============================================================================
# Oracle FPP (Fleet Patching and Provisioning) — 19c (19.3.0)
# on Oracle Linux 7
# ==============================================================================
#
# Copy this file to vagrant.yml and edit. vagrant.yml is gitignored so your
# local credentials stay out of source control.
#
#     cp config/vagrant.yml.example config/vagrant.yml
#
# Only one provider block should be active at a time — the one matching
# `env.provider`.
#
# CREDENTIALS
#   The defaults below are DISTINCT placeholders, not a real password policy.
#   Replace them before any real use. Every password can also be supplied at
#   run time via an environment variable, which overrides the YAML value:
#
#       ORACLE_RAC_ROOT_PASSWORD    (overrides root_password)
#       ORACLE_RAC_GRID_PASSWORD    (overrides grid_password)
#       ORACLE_RAC_ORACLE_PASSWORD  (overrides oracle_password)
#       ORACLE_RAC_SYS_PASSWORD     (overrides sys_password)
#
#   Never commit a vagrant.yml that contains real credentials.
#
# ------------------------------------------------------------------------------

# -------------------------------- Active profile -------------------------------
# -----------------------------------------------
# vagrant.yml for VirtualBox
# -----------------------------------------------
host1:
  vm_name: fpps
  mem_size: 16384
  cpus: 1
  public_ip:     192.168.56.101
  vip_ip:        192.168.56.102
  scan_ip1:      192.168.56.105
  scan_ip2:      192.168.56.106
  scan_ip3:      192.168.56.107
  gns_ip:        192.168.56.108
  ha_vip:        192.168.56.109
  private_ip:    192.168.200.101
  u01_disk: ./fpps_u01.vdi

host2:
  vm_name: fppc
  mem_size: 8192
  cpus: 4
  public_ip: 192.168.56.201
  private_ip: 192.168.200.102
  u01_disk: ./fppc_u01.vdi
  deploy: 'true'

shared:
  prefix_name:   fpp193-ol8
  # ---------------------------------------------
  network:       hostonly
  netmask:       
  gateway:       
  dns_public_ip: 
  domain:        localdomain
  # ---------------------------------------------
  non_rotational: 'on'
  # ---------------------------------------------
  asm_disk_path: 
  asm_disk_num:  4
  asm_disk_size: 50
  # ---------------------------------------------

env:
  provider: virtualbox
  # ---------------------------------------------
  gi_software: LINUX.X64_193000_grid_home.zip
  db_software: LINUX.X64_193000_db_home.zip
  # ---------------------------------------------
  root_password:   welcome1
  grid_password:   welcome1
  oracle_password: welcome1
  sys_password:    welcome1
  # ---------------------------------------------
  ora_languages:   en,en_GB
  # ---------------------------------------------


