#!/usr/bin/env expect -f
#------------------------------------------------------------------------------
# LICENSE UPL 1.0
# Copyright (c) 1982-2026 Oracle and/or its affiliates. All rights reserved.
#
# 08_setup_user_equ.expect
#   Drive sshUserSetup.sh for a given user across two hosts. Called exclusively
#   by 08_setup_user_equ.sh which supplies the password via the
#   RAC_USER_PASSWORD environment variable (never via argv).
#
#   Args (argv, safe to appear in 'ps'):
#     [0] username
#     [1] node1 hostname
#     [2] node2 hostname
#     [3] path to sshUserSetup.sh
#
#   Env (secret — not visible in 'ps'):
#     RAC_USER_PASSWORD   user's OS password
#------------------------------------------------------------------------------
set timeout 60

if { [llength $argv] != 4 } {
  send_error "usage: expect ... <user> <node1> <node2> <sshUserSetup.sh>\n"
  exit 1
}

set username [lindex $argv 0]
set node1    [lindex $argv 1]
set node2    [lindex $argv 2]
set setup    [lindex $argv 3]

if { ![info exists env(RAC_USER_PASSWORD)] } {
  send_error "RAC_USER_PASSWORD env var is required\n"
  exit 1
}
set password $env(RAC_USER_PASSWORD)

spawn $setup -user $username -hosts "$node1 $node2" -noPromptPassphrase -advanced

expect {
  -re "continue and let the script make the above mentioned changes.*\\(yes/no\\)\\?" {
    send "yes\r"
    exp_continue
  }
  -re "password:" {
    send "$password\r"
    exp_continue
  }
  -re "Permission denied" {
    send_error "sshUserSetup.sh reported 'Permission denied' for user $username\n"
    exit 2
  }
  eof
}

# sshUserSetup.sh prints its own SUCCESS line; we just return its exit code.
catch wait result
exit [lindex $result 3]
