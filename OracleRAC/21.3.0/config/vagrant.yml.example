# ==============================================================================
# Oracle Real Application Clusters (RAC) — Oracle Database 21c (21.3.0)
# on Oracle Linux 8
# ==============================================================================
#
# Copy this file to vagrant.yml and edit. vagrant.yml is gitignored so your
# local credentials stay out of source control.
#
#     cp config/vagrant.yml.example config/vagrant.yml
#
# Only one provider block should be active at a time — the one matching
# `env.provider`.
#
# CREDENTIALS
#   The defaults below are DISTINCT placeholders, not a real password policy.
#   Replace them before any real use. Every password can also be supplied at
#   run time via an environment variable, which overrides the YAML value:
#
#       ORACLE_RAC_ROOT_PASSWORD    (overrides root_password)
#       ORACLE_RAC_GRID_PASSWORD    (overrides grid_password)
#       ORACLE_RAC_ORACLE_PASSWORD  (overrides oracle_password)
#       ORACLE_RAC_SYS_PASSWORD     (overrides sys_password)
#       ORACLE_RAC_PDB_PASSWORD     (overrides pdb_password)
#
#   Never commit a vagrant.yml that contains real credentials.
#
# ------------------------------------------------------------------------------

## -------------------------------- Active profile -------------------------------
host1:
  vm_name:    node1
  mem_size:   8192            # MB — minimum 6144
  cpus:       2
  public_ip:  192.168.56.111
  vip_ip:     192.168.56.112
  private_ip: 192.168.200.111
  storage_pool_name: Vagrant_KVM_Storage

host2:
  vm_name:    node2
  mem_size:   8192
  cpus:       2
  public_ip:  192.168.56.121
  vip_ip:     192.168.56.122
  private_ip: 192.168.200.122
  storage_pool_name: Vagrant_KVM_Storage

env:
  provider:          virtualbox
  prefix_name:       rac21-ol8
  domain:            localdomain

  # SCAN addresses — three IPs in the same subnet as public_ip
  scan_ip1:          192.168.56.115
  scan_ip2:          192.168.56.116
  scan_ip3:          192.168.56.117

  # Shared ASM disks
  asm_disk_path:
  asm_disk_num:      4          # minimum 4
  asm_disk_size:     20         # GB per disk
  p1_ratio:          80         # size ratio between P1 (DATA) and P2 (RECO), 10..80
  storage_pool_name: Vagrant_KVM_Storage

  # Oracle Database 21c (21.3.0) Grid Infrastructure and RDBMS installers.
  # Download from:
  #   https://www.oracle.com/database/technologies/oracle21c-linux-downloads.html
  gi_software:       LINUX.X64_213000_grid_home.zip
  db_software:       LINUX.X64_213000_db_home.zip

  # Credentials — DISTINCT DEMO PLACEHOLDERS. Change these before real use.
  root_password:     DemoRoot_1
  grid_password:     DemoGrid_1
  oracle_password:   DemoOra_1
  sys_password:      DemoSys_1
  pdb_password:      DemoPdb_1

  ora_languages:     en,en_GB

  # Cluster / database layout
  nomgmtdb:          true       # skip GI Management Repository
  orestart:          false      # true = Oracle Restart (SI only); false = cluster
  db_name:           DB21H1
  pdb_name:          PDB1
  db_type:           RAC        # RAC | RACONE | SI
  cdb:               true

